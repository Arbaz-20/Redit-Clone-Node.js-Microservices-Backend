# ─────────────────────────────────────────────────────────────
# Reddit Clone Microservices — environment template
# Copy to `.env` (cp .env.example .env) before running docker compose.
# ─────────────────────────────────────────────────────────────

# --- Shared secrets ---
JWT_SECRET=super_secret_change_me_in_production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# --- Postgres (single instance, one database per service) ---
POSTGRES_USER=reddit
POSTGRES_PASSWORD=reddit_pass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- RabbitMQ ---
RABBITMQ_URL=amqp://reddit:reddit_pass@rabbitmq:5672
RABBITMQ_USER=reddit
RABBITMQ_PASSWORD=reddit_pass
RABBITMQ_EXCHANGE=reddit.events

# --- API Gateway ---
GATEWAY_PORT=8080
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
CORS_ORIGIN=*

# --- Internal service ports (container-internal) ---
AUTH_SERVICE_PORT=4001
USER_SERVICE_PORT=4002
COMMUNITY_SERVICE_PORT=4003
POST_SERVICE_PORT=4004
COMMENT_SERVICE_PORT=4005
VOTE_SERVICE_PORT=4006
FEED_SERVICE_PORT=4007
NOTIFICATION_SERVICE_PORT=4008
