{
  "name": "auth-service",
  "version": "1.0.0",
  "description": "Authentication service — register, login, JWT issuance",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node dist/db/run-migrate.js"
  },
  "dependencies": {
    "amqplib": "^0.10.4",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.0",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "joi": "^17.13.3",
    "pg": "^8.12.0",
    "uuid": "^10.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.28.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
